---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: 'Real-Time Log Streaming',
    description: 'Tail logs live from any service, container, or server. Full-text search across millions of events in milliseconds.',
    color: 'from-cyan-500 to-blue-500',
    glow: 'shadow-cyan-500/20',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Job Schedule Monitoring',
    description: 'Track every cron job, queue worker, and scheduled task. Get alerted the moment a job is late, fails, or hangs.',
    color: 'from-emerald-500 to-teal-500',
    glow: 'shadow-emerald-500/20',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>`,
    title: 'Smart Alerting',
    description: 'Route alerts to Slack, PagerDuty, email, or webhooks. Define thresholds, anomaly detection, and on-call schedules.',
    color: 'from-orange-500 to-rose-500',
    glow: 'shadow-orange-500/20',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
    title: 'Custom Dashboards',
    description: 'Build powerful dashboards with log volume charts, error rates, job success metrics, and P95 latency graphs.',
    color: 'from-violet-500 to-purple-500',
    glow: 'shadow-violet-500/20',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    title: 'Structured Log Parsing',
    description: 'Automatically parse JSON, logfmt, and custom log formats. Extract fields, build facets, and run SQL-like queries.',
    color: 'from-yellow-500 to-amber-500',
    glow: 'shadow-yellow-500/20',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'Team Collaboration',
    description: 'Shared saved searches, annotate log events, assign incidents, and control access with fine-grained RBAC.',
    color: 'from-pink-500 to-rose-500',
    glow: 'shadow-pink-500/20',
  },
];

const testimonials = [
  {
    quote: 'Pulsebeat caught a silent cron job failure that had been losing data for 3 days. The dead-man switch alerting paid for itself on day one.',
    name: 'Marcus Webb',
    role: 'Staff SRE at DataStream',
    avatar: 'MW',
    gradient: 'from-cyan-500 to-blue-500',
  },
  {
    quote: "We replaced three separate tools with Pulsebeat. Our on-call team gets half the alerts they used to, and every alert actually means something now.",
    name: 'Priya Nair',
    role: 'Engineering Manager at FinCore',
    avatar: 'PN',
    gradient: 'from-emerald-500 to-teal-500',
  },
  {
    quote: 'The job monitoring dashboard is incredible. I can see at a glance which ETL pipelines ran, how long they took, and exactly where failures occurred.',
    name: 'Tom Erikson',
    role: 'Data Platform Lead at ScaleOps',
    avatar: 'TE',
    gradient: 'from-violet-500 to-purple-500',
  },
];

const pricingPlans = [
  {
    name: 'Hobby',
    price: 'Free',
    period: '',
    description: 'Perfect for side projects and personal use.',
    features: [
      '3 monitored jobs',
      '1 GB log retention / month',
      '24-hour log history',
      'Email alerts',
      'Community support',
    ],
    cta: 'Get Started Free',
    highlight: false,
  },
  {
    name: 'Pro',
    price: '$29',
    period: '/ month',
    description: 'For teams serious about reliability.',
    features: [
      'Unlimited monitored jobs',
      '50 GB log retention / month',
      '30-day log history',
      'Slack, PagerDuty & webhooks',
      'Custom dashboards',
      'Structured log parsing',
      'Priority support',
    ],
    cta: 'Start Pro Trial',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'For large-scale infrastructure teams.',
    features: [
      'Everything in Pro',
      'Unlimited log retention',
      'SSO & SAML',
      'Fine-grained RBAC',
      'Audit logs',
      'Dedicated SLA',
      'Onboarding & training',
    ],
    cta: 'Contact Sales',
    highlight: false,
  },
];
---

<Layout title="Pulsebeat — Monitor Jobs & Logs in Real Time" description="Real-time monitoring for cron jobs, log streams, and infrastructure. Get instant alerts when things go wrong.">

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-gray-950">
    <!-- Gradient glow blobs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] bg-cyan-500/10 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 right-0 w-[500px] h-[500px] bg-emerald-500/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] bg-violet-500/8 rounded-full blur-3xl"></div>
    </div>

    <!-- Grid overlay -->
    <div class="absolute inset-0 opacity-[0.04]"
      style="background-image: linear-gradient(to right, #4ade80 1px, transparent 1px), linear-gradient(to bottom, #4ade80 1px, transparent 1px); background-size: 48px 48px;">
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-40">
      <div class="max-w-4xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium mb-8">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          Now monitoring 2.4 billion log events / day
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-white leading-[1.05] mb-6 tracking-tight">
          Monitor every job.
          <br />
          <span class="bg-gradient-to-r from-cyan-400 via-emerald-400 to-teal-400 bg-clip-text text-transparent">
            Catch every failure.
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="text-xl md:text-2xl text-gray-400 leading-relaxed mb-10 max-w-2xl">
          Pulsebeat gives your team real-time visibility into cron jobs, background workers, and log streams — with instant alerts before your users notice anything.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a
            href="#"
            class="group px-8 py-4 text-base font-bold text-gray-950 bg-gradient-to-r from-cyan-400 to-emerald-400 rounded-xl hover:from-cyan-300 hover:to-emerald-300 transition-all duration-300 shadow-xl shadow-cyan-500/20 hover:shadow-cyan-500/30 hover:-translate-y-0.5 flex items-center gap-2"
            data-confetti
          >
            Start monitoring free
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="#"
            class="group px-8 py-4 text-base font-bold text-gray-300 border border-gray-700 rounded-xl hover:bg-gray-800 hover:border-gray-600 hover:text-white transition-all duration-300 flex items-center gap-2"
          >
            <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Watch demo
          </a>
        </div>

        <!-- Trust bar -->
        <p class="mt-6 text-gray-600 text-sm">No credit card required &nbsp;·&nbsp; 14-day free trial &nbsp;·&nbsp; Cancel anytime</p>
      </div>

      <!-- Terminal preview -->
      <div class="mt-16 max-w-3xl">
        <div class="bg-gray-900 rounded-2xl border border-gray-700/60 shadow-2xl shadow-black/50 overflow-hidden">
          <!-- Terminal top bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-gray-800/60 border-b border-gray-700/60">
            <span class="w-3 h-3 rounded-full bg-rose-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-emerald-500/80"></span>
            <span class="ml-3 text-gray-500 text-xs font-mono">logpulse — live stream</span>
            <span class="ml-auto flex items-center gap-1.5 text-emerald-400 text-xs font-mono">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
              LIVE
            </span>
          </div>
          <!-- Log lines -->
          <div class="p-4 font-mono text-xs leading-6 space-y-0.5 overflow-hidden">
            <div class="flex gap-3">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:02</span>
              <span class="text-emerald-400">[INFO]</span>
              <span class="text-gray-300">job:daily-report <span class="text-cyan-400">started</span> &nbsp;duration_limit=300s</span>
            </div>
            <div class="flex gap-3">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:04</span>
              <span class="text-emerald-400">[INFO]</span>
              <span class="text-gray-300">db:query rows_fetched=<span class="text-yellow-400">48293</span> &nbsp;elapsed=<span class="text-yellow-400">1.24s</span></span>
            </div>
            <div class="flex gap-3">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:06</span>
              <span class="text-emerald-400">[INFO]</span>
              <span class="text-gray-300">s3:upload file=report_2026-04-02.csv &nbsp;size=<span class="text-cyan-400">2.1MB</span></span>
            </div>
            <div class="flex gap-3">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:07</span>
              <span class="text-rose-400 font-semibold">[ERROR]</span>
              <span class="text-gray-300">smtp:send <span class="text-rose-400">Connection refused</span> &nbsp;host=mail.internal retry=1/3</span>
            </div>
            <div class="flex gap-3">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:09</span>
              <span class="text-yellow-400">[WARN]</span>
              <span class="text-gray-300">smtp:send <span class="text-yellow-400">retry 2/3</span> &nbsp;backoff=2s</span>
            </div>
            <div class="flex gap-3 bg-rose-500/10 rounded px-1 -mx-1">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:11</span>
              <span class="text-rose-400 font-semibold">[ERROR]</span>
              <span class="text-rose-300">smtp:send <span class="font-bold">FAILED after 3 retries</span> — alert dispatched to #ops-alerts</span>
            </div>
            <div class="flex gap-3">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:11</span>
              <span class="text-cyan-400">[ALERT]</span>
              <span class="text-gray-300">Slack notification sent &nbsp;channel=<span class="text-cyan-400">#ops-alerts</span></span>
            </div>
            <div class="flex gap-3">
              <span class="text-gray-600 shrink-0">2026-04-02 09:14:12</span>
              <span class="text-emerald-400">[INFO]</span>
              <span class="text-gray-300">job:daily-report <span class="text-emerald-400">completed</span> &nbsp;exit_code=<span class="text-yellow-400">1</span> &nbsp;elapsed=<span class="text-cyan-400">10.4s</span></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="border-y border-gray-800/60 bg-gray-900/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: '2.4B+', label: 'Log events / day' },
          { value: '99.99%', label: 'Platform uptime' },
          { value: '<50ms', label: 'Alert latency' },
          { value: '12,000+', label: 'Teams monitoring' },
        ].map(stat => (
          <div>
            <div class="text-3xl font-extrabold text-white mb-1">{stat.value}</div>
            <div class="text-sm text-gray-500 uppercase tracking-wide">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FEATURES ═══ -->
  <section id="features" class="py-24 bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-4">
          Platform Features
        </div>
        <h2 class="text-4xl font-extrabold text-white mb-4">
          Full observability,
          <span class="bg-gradient-to-r from-cyan-400 to-emerald-400 bg-clip-text text-transparent"> zero blind spots</span>
        </h2>
        <p class="text-gray-400 text-lg leading-relaxed">
          Everything your on-call team needs to monitor, debug, and resolve incidents faster.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(feature => (
          <div class="group relative bg-gray-900/60 border border-gray-800/60 rounded-2xl p-6 hover:border-gray-700 hover:bg-gray-900 transition-all duration-300 hover:-translate-y-0.5">
            <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br ${feature.color} text-white mb-4 shadow-lg ${feature.glow}`} set:html={feature.icon}></div>
            <h3 class="text-lg font-bold text-white mb-2">{feature.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="py-24 bg-gray-900/40 border-y border-gray-800/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-400 text-sm font-medium mb-4">
          Get Started in Minutes
        </div>
        <h2 class="text-4xl font-extrabold text-white mb-4">Up and running fast</h2>
        <p class="text-gray-400 text-lg">Integrate with one line of code. No agents to install, no infrastructure to manage.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            step: '01',
            title: 'Send your logs',
            desc: 'Point your app at our ingest endpoint via HTTP, syslog, or one of our SDKs for Node, Python, Go, and Ruby.',
            code: `curl -X POST https://ingest.logpulse.io/v1/logs \\
  -H "Authorization: Bearer $LP_KEY" \\
  -d '{"level":"info","msg":"job started","job":"daily-report"}'`,
          },
          {
            step: '02',
            title: 'Register your jobs',
            desc: 'Add a ping URL to your cron job or worker. Pulsebeat detects misses, long runs, and crashes automatically.',
            code: `# At the end of your cron job
curl https://ping.logpulse.io/abc123/succeed

# Or wrap with our CLI
logpulse exec --job daily-report -- python report.py`,
          },
          {
            step: '03',
            title: 'Get alerted instantly',
            desc: 'Define alert rules in the UI or as code. Receive Slack, PagerDuty, or email notifications within seconds.',
            code: `# logpulse.yaml
alerts:
  - name: job-failure
    condition: job.exit_code != 0
    channels: [slack:#ops-alerts, pagerduty]
    severity: critical`,
          },
        ].map(step => (
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <span class="text-5xl font-extrabold text-gray-800 leading-none">{step.step}</span>
              <h3 class="text-xl font-bold text-white">{step.title}</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">{step.desc}</p>
            <pre class="bg-gray-900 border border-gray-700/60 rounded-xl p-4 text-xs text-emerald-300 font-mono leading-6 overflow-x-auto whitespace-pre-wrap">{step.code}</pre>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="py-24 bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium mb-4">
          Customer Stories
        </div>
        <h2 class="text-4xl font-extrabold text-white mb-4">Trusted by on-call teams worldwide</h2>
        <p class="text-gray-400 text-lg">Hear from the SREs and platform engineers who rely on Pulsebeat every day.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-gray-900/60 border border-gray-800/60 rounded-2xl p-8 hover:border-gray-700 transition-all duration-300">
            <div class="flex gap-1 mb-5">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <blockquote class="text-gray-300 text-sm leading-relaxed mb-6">"{t.quote}"</blockquote>
            <div class="flex items-center gap-3">
              <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${t.gradient} flex items-center justify-center text-white font-bold text-sm shadow-md`}>
                {t.avatar}
              </div>
              <div>
                <p class="font-semibold text-white text-sm">{t.name}</p>
                <p class="text-gray-500 text-xs">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PRICING ═══ -->
  <section id="pricing" class="py-24 bg-gray-900/40 border-t border-gray-800/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-4">
          Pricing
        </div>
        <h2 class="text-4xl font-extrabold text-white mb-4">Simple, transparent pricing</h2>
        <p class="text-gray-400 text-lg">Start free. Scale as your team grows. No per-seat pricing.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        {pricingPlans.map(plan => (
          <div class={`relative rounded-2xl p-8 border transition-all duration-300 ${
            plan.highlight
              ? 'bg-gradient-to-b from-cyan-500/10 to-emerald-500/5 border-cyan-500/30 shadow-2xl shadow-cyan-500/10'
              : 'bg-gray-900/60 border-gray-800/60 hover:border-gray-700'
          }`}>
            {plan.highlight && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="px-4 py-1 rounded-full bg-gradient-to-r from-cyan-500 to-emerald-500 text-gray-950 text-xs font-bold uppercase tracking-wider shadow-lg">
                  Most Popular
                </span>
              </div>
            )}

            <h3 class="text-lg font-bold text-white mb-1">{plan.name}</h3>
            <p class="text-gray-500 text-sm mb-4">{plan.description}</p>
            <div class="flex items-end gap-1 mb-6">
              <span class="text-4xl font-extrabold text-white">{plan.price}</span>
              {plan.period && <span class="text-gray-500 text-sm mb-1">{plan.period}</span>}
            </div>

            <ul class="space-y-3 mb-8">
              {plan.features.map(feature => (
                <li class="flex items-center gap-2.5 text-sm text-gray-400">
                  <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <a
              href="#"
              class={`block w-full py-3 rounded-xl text-sm font-bold text-center transition-all duration-200 ${
                plan.highlight
                  ? 'bg-gradient-to-r from-cyan-400 to-emerald-400 text-gray-950 hover:from-cyan-300 hover:to-emerald-300 shadow-lg shadow-cyan-500/20'
                  : 'bg-gray-800 text-gray-200 hover:bg-gray-700 border border-gray-700'
              }`}
              data-confetti
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BLOG PREVIEW ═══ -->
  {posts.length > 0 && (
    <section class="py-24 bg-gray-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-12 gap-4">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-400 text-sm font-medium mb-3">
              Engineering Blog
            </div>
            <h2 class="text-4xl font-extrabold text-white">From the team</h2>
          </div>
          <a href="/blog" class="group flex items-center gap-1.5 text-sm font-semibold text-cyan-400 hover:text-cyan-300 transition-colors">
            View all posts
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post, i) => (
            <a href={`/blog/${post.slug}`} class="group flex flex-col bg-gray-900/60 border border-gray-800/60 rounded-2xl overflow-hidden hover:border-gray-700 hover:-translate-y-0.5 transition-all duration-300">
              <div class={`h-36 bg-gradient-to-br ${
                i === 0 ? 'from-cyan-600 to-blue-700' :
                i === 1 ? 'from-emerald-600 to-teal-700' :
                'from-violet-600 to-purple-700'
              } flex items-end p-5 relative overflow-hidden`}>
                <div class="absolute top-3 right-3 flex gap-1">
                  <span class="w-2 h-2 rounded-full bg-white/30"></span>
                  <span class="w-2 h-2 rounded-full bg-white/20"></span>
                  <span class="w-2 h-2 rounded-full bg-white/10"></span>
                </div>
                {post.data.tags?.[0] && (
                  <span class="px-2.5 py-0.5 rounded-md bg-black/30 text-white/80 text-xs font-mono border border-white/10">
                    #{post.data.tags[0]}
                  </span>
                )}
              </div>
              <div class="flex flex-col flex-1 p-5">
                <h3 class="text-base font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="text-gray-500 text-sm leading-relaxed flex-1 line-clamp-2">{post.data.description}</p>
                <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-800/60">
                  <span class="text-xs text-gray-600">{post.data.author}</span>
                  <time class="text-xs text-gray-600">
                    {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA BANNER ═══ -->
  <section class="py-24 bg-gray-900/40 border-t border-gray-800/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-3xl overflow-hidden bg-gradient-to-br from-gray-900 via-cyan-950/40 to-emerald-950/30 border border-cyan-500/20 p-8 sm:p-12 md:p-16 text-center">
        <div class="absolute inset-0 opacity-[0.04]"
          style="background-image: linear-gradient(to right, #06b6d4 1px, transparent 1px), linear-gradient(to bottom, #06b6d4 1px, transparent 1px); background-size: 32px 32px;">
        </div>
        <div class="relative">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            Start in under 5 minutes
          </div>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">
            Stop flying blind.<br class="hidden sm:block" />
            <span class="bg-gradient-to-r from-cyan-400 to-emerald-400 bg-clip-text text-transparent">Start monitoring today.</span>
          </h2>
          <p class="text-gray-400 text-lg max-w-xl mx-auto mb-8">
            Join 12,000+ engineering teams who trust Pulsebeat to keep their systems healthy and their on-call engineers sane.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#" class="px-8 py-4 font-bold text-gray-950 bg-gradient-to-r from-cyan-400 to-emerald-400 rounded-xl hover:from-cyan-300 hover:to-emerald-300 transition-all duration-200 shadow-xl shadow-cyan-500/20" data-confetti>
              Start free — no credit card
            </a>
            <a href="#" class="px-8 py-4 font-bold text-gray-200 border border-gray-700 rounded-xl hover:bg-gray-800 hover:text-white transition-all duration-200">
              Talk to sales
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
