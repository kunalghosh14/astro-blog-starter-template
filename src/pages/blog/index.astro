---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const gradients = [
  'from-cyan-600 to-blue-700',
  'from-emerald-600 to-teal-700',
  'from-violet-600 to-purple-700',
  'from-orange-600 to-rose-700',
  'from-sky-600 to-indigo-700',
  'from-pink-600 to-rose-700',
];

const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];
---

<Layout title="Engineering Blog | Pulsebeat" description="Deep dives into monitoring, observability, log management, SRE practices, and building reliable systems.">
  <!-- Page Header -->
  <div class="relative bg-gray-950 overflow-hidden border-b border-gray-800/60">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 right-1/4 w-80 h-80 bg-cyan-500/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 w-64 h-64 bg-emerald-500/8 rounded-full blur-3xl"></div>
    </div>
    <div class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(to right, #06b6d4 1px, transparent 1px), linear-gradient(to bottom, #06b6d4 1px, transparent 1px); background-size: 48px 48px;">
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          {posts.length} Articles Published
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4 leading-tight">
          The Pulsebeat<br />Engineering Blog
        </h1>
        <p class="text-lg text-gray-400 leading-relaxed max-w-xl">
          Practical guides on monitoring, observability, structured logging, SRE practices, and building reliable distributed systems.
        </p>
      </div>
    </div>
  </div>

  <!-- Tags Filter -->
  {allTags.length > 0 && (
    <div class="bg-gray-900/80 border-b border-gray-800/60 sticky top-16 z-30 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <div class="flex items-center gap-2 overflow-x-auto">
          <span class="text-xs font-medium text-gray-600 whitespace-nowrap uppercase tracking-wide">Topics:</span>
          <a href="/blog" class="px-3 py-1 text-xs font-medium text-cyan-400 bg-cyan-500/10 border border-cyan-500/20 rounded-full hover:bg-cyan-500/20 transition-colors whitespace-nowrap">
            All
          </a>
          {allTags.map(tag => (
            <span class="px-3 py-1 text-xs font-medium text-gray-400 bg-gray-800 border border-gray-700/60 rounded-full hover:text-gray-200 hover:border-gray-600 transition-colors whitespace-nowrap cursor-pointer font-mono">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Blog Posts Grid -->
  <section class="py-16 bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="text-center py-24">
          <div class="w-20 h-20 rounded-full bg-gray-900 flex items-center justify-center mx-auto mb-6 border border-gray-800">
            <svg class="w-10 h-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-white mb-2">No posts yet</h2>
          <p class="text-gray-500">Check back soon for new articles.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post, index) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col bg-gray-900/60 border border-gray-800/60 rounded-2xl overflow-hidden hover:border-gray-700 hover:-translate-y-0.5 transition-all duration-300"
            >
              <!-- Card Header -->
              <div class={`relative h-44 bg-gradient-to-br ${gradients[index % gradients.length]} overflow-hidden`}>
                <div class="absolute inset-0 opacity-10"
                  style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 24px 24px;">
                </div>
                <div class="absolute top-3 right-3">
                  <span class="px-2 py-1 text-xs font-mono font-bold text-white/70 bg-black/20 backdrop-blur-sm rounded-md border border-white/10">
                    #{String(index + 1).padStart(2, '0')}
                  </span>
                </div>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="absolute bottom-4 left-4 flex gap-2">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="px-2 py-0.5 text-xs font-mono text-white/80 bg-black/30 backdrop-blur-sm rounded-md border border-white/10">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              <!-- Card Content -->
              <div class="flex flex-col flex-1 p-5">
                <h2 class="text-base font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors line-clamp-2 leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-gray-500 text-sm leading-relaxed flex-1 line-clamp-2 mb-4">
                  {post.data.description}
                </p>

                <div class="flex items-center justify-between pt-4 border-t border-gray-800/60">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-gradient-to-br from-cyan-500 to-emerald-500 flex items-center justify-center text-white text-xs font-bold">
                      {(post.data.author || 'A').charAt(0)}
                    </div>
                    <span class="text-xs text-gray-500">{post.data.author}</span>
                  </div>
                  <time class="text-xs text-gray-600" datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>

                <div class="mt-4 flex items-center gap-1.5 text-cyan-400 text-xs font-semibold group-hover:gap-2.5 transition-all">
                  Read article
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 bg-gray-900/40 border-t border-gray-800/60">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium mb-4">
        Stay Updated
      </div>
      <h2 class="text-3xl font-extrabold text-white mb-3">
        Get new articles in your inbox
      </h2>
      <p class="text-gray-400 mb-8">
        We publish deep dives on monitoring, reliability, and SRE practices. No spam.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="you@company.com"
          class="flex-1 px-4 py-3 bg-gray-800 border border-gray-700 rounded-xl text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500/50 text-sm"
        />
        <button
          type="submit"
          class="px-6 py-3 font-bold text-gray-950 bg-gradient-to-r from-cyan-400 to-emerald-400 rounded-xl hover:from-cyan-300 hover:to-emerald-300 transition-all duration-200 shadow-lg shadow-cyan-500/20 text-sm whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>
</Layout>
