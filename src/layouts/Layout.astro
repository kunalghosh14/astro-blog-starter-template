---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Pulsebeat — Real-time monitoring for jobs, logs, and infrastructure.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="font-sans bg-gray-950 text-gray-100 antialiased">
    <!-- Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-md border-b border-gray-800/60">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-500 to-emerald-500 flex items-center justify-center shadow-lg shadow-cyan-500/20">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <span class="font-bold text-xl text-white">Pulse<span class="text-cyan-400">beat</span></span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-1">
            <a
              href="/"
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
                currentPath === '/'
                  ? 'bg-cyan-500/10 text-cyan-400'
                  : 'text-gray-400 hover:text-gray-100 hover:bg-gray-800/60'
              }`}
            >
              Home
            </a>
            <a
              href="/#features"
              class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-100 hover:bg-gray-800/60 transition-all duration-200"
            >
              Features
            </a>
            <a
              href="/#pricing"
              class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-100 hover:bg-gray-800/60 transition-all duration-200"
            >
              Pricing
            </a>
            <a
              href="/blog"
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
                currentPath.startsWith('/blog')
                  ? 'bg-cyan-500/10 text-cyan-400'
                  : 'text-gray-400 hover:text-gray-100 hover:bg-gray-800/60'
              }`}
            >
              Blog
            </a>
          </div>

          <!-- CTA Buttons -->
          <div class="hidden md:flex items-center gap-3">
            <a href="#" class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white transition-colors">
              Sign in
            </a>
            <a
              href="#"
              class="px-4 py-2 text-sm font-semibold text-gray-950 bg-gradient-to-r from-cyan-400 to-emerald-400 rounded-lg hover:from-cyan-300 hover:to-emerald-300 transition-all duration-200 shadow-lg shadow-cyan-500/20"
              data-confetti
            >
              Start Free
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition-colors"
            aria-label="Toggle menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4 pt-2 border-t border-gray-800">
          <div class="flex flex-col gap-1">
            <a href="/" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-800 transition-colors">Home</a>
            <a href="/#features" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-800 transition-colors">Features</a>
            <a href="/#pricing" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-800 transition-colors">Pricing</a>
            <a href="/blog" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-800 transition-colors">Blog</a>
            <a href="#" class="mt-2 px-4 py-2 text-sm font-semibold text-gray-950 bg-gradient-to-r from-cyan-400 to-emerald-400 rounded-lg text-center">
              Start Free
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-950 border-t border-gray-800/60">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-12">
          <!-- Brand -->
          <div class="col-span-1 md:col-span-2">
            <a href="/" class="flex items-center gap-2.5 mb-4">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-500 to-emerald-500 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
              <span class="font-bold text-xl text-white">Pulse<span class="text-cyan-400">beat</span></span>
            </a>
            <p class="text-gray-500 text-sm leading-relaxed max-w-xs">
              Real-time monitoring for jobs, logs, and infrastructure. Never miss a failure again.
            </p>
            <div class="flex gap-3 mt-6">
              <a href="#" class="w-9 h-9 rounded-lg bg-gray-800 flex items-center justify-center text-gray-500 hover:text-white hover:bg-cyan-500/20 hover:border-cyan-500/40 border border-transparent transition-all duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
              </a>
              <a href="#" class="w-9 h-9 rounded-lg bg-gray-800 flex items-center justify-center text-gray-500 hover:text-white hover:bg-cyan-500/20 border border-transparent transition-all duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
              </a>
            </div>
          </div>

          <div>
            <h3 class="text-gray-200 font-semibold text-sm uppercase tracking-wider mb-4">Product</h3>
            <ul class="space-y-3">
              <li><a href="/#features" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Features</a></li>
              <li><a href="/#pricing" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Pricing</a></li>
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Changelog</a></li>
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Roadmap</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-gray-200 font-semibold text-sm uppercase tracking-wider mb-4">Developers</h3>
            <ul class="space-y-3">
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Documentation</a></li>
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">API Reference</a></li>
              <li><a href="/blog" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Blog</a></li>
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Status Page</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-gray-200 font-semibold text-sm uppercase tracking-wider mb-4">Company</h3>
            <ul class="space-y-3">
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">About</a></li>
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Careers</a></li>
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Privacy</a></li>
              <li><a href="#" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">Terms</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-gray-800/60 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-gray-600 text-sm">
            &copy; {new Date().getFullYear()} Pulsebeat, Inc. All rights reserved.
          </p>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-gray-600 text-sm">All systems operational</span>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => menu.classList.toggle('hidden'));
      }
    </script>

    <script>
      import confetti from 'canvas-confetti';

      document.querySelectorAll('[data-confetti]').forEach(el => {
        el.addEventListener('click', (e) => {
          const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
          const x = (rect.left + rect.width / 2) / window.innerWidth;
          const y = (rect.top + rect.height / 2) / window.innerHeight;

          confetti({
            particleCount: 120,
            spread: 80,
            origin: { x, y },
            colors: ['#22d3ee', '#34d399', '#a78bfa', '#f9a8d4', '#fde68a'],
            startVelocity: 35,
            gravity: 0.9,
            scalar: 1.1,
          });
        });
      });
    </script>
  </body>
</html>
